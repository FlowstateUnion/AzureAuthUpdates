# Azure Automation Auth Modernization — Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by all project scripts.
# NEVER commit .env to source control (it's in .gitignore).

# --- Azure Subscription ---
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_TENANT_NAME=contoso.onmicrosoft.com

# --- Automation Account ---
AUTOMATION_RESOURCE_GROUP=
AUTOMATION_ACCOUNT_NAME=
AUTOMATION_RUNTIME_ENV=PS74-ModernAuth

# --- Managed Identity ---
# Object ID of the System-Assigned MI (from Entra ID > Enterprise Applications)
MANAGED_IDENTITY_OBJECT_ID=
# Client ID of User-Assigned MI (leave blank if using System-Assigned)
USER_ASSIGNED_MI_CLIENT_ID=

# --- Key Vault ---
KEYVAULT_NAME=
KEYVAULT_RESOURCE_GROUP=

# --- SharePoint ---
SHAREPOINT_TENANT_PREFIX=contoso
SHAREPOINT_ADMIN_URL=https://contoso-admin.sharepoint.com
SHAREPOINT_TEST_SITE_URL=https://contoso.sharepoint.com/sites/TestSite

# --- Exchange Online ---
EXCHANGE_ORGANIZATION=contoso.onmicrosoft.com

# --- App Registration (for certificate-based auth fallback) ---
APP_REGISTRATION_CLIENT_ID=
APP_REGISTRATION_CERT_THUMBPRINT=

# --- Module Installation ---
# Scope for Install-Module: CurrentUser or AllUsers
# Use CurrentUser for local testing, AllUsers for servers/Hybrid Workers
MODULE_INSTALL_SCOPE=CurrentUser

# --- Storage Account (for module deployment) ---
STORAGE_ACCOUNT_NAME=
STORAGE_CONTAINER_NAME=automation-modules
